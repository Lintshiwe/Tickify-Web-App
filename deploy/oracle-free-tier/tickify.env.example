# Tickify runtime environment for Oracle Cloud VM

JAVA_OPTS="-Xms128m -Xmx384m -Djava.awt.headless=true -Dtickify.app.baseUrl=http://YOUR_VM_PUBLIC_IP:8080"

# Database credentials
TICKIFY_DB_USER=YOUR_DB_USER
TICKIFY_DB_PASSWORD=YOUR_DB_PASSWORD
TICKIFY_DB_HOST=127.0.0.1
TICKIFY_DB_PORT=1527
TICKIFY_DB_NAME=tickifyDB

# SMTP (optional but recommended)
TICKIFY_SMTP_HOST=smtp.gmail.com
TICKIFY_SMTP_PORT=587
TICKIFY_SMTP_USER=YOUR_SMTP_USER
TICKIFY_SMTP_PASSWORD=YOUR_SMTP_PASSWORD
TICKIFY_SMTP_FROM=no-reply@tickify.ac.za
TICKIFY_SMTP_STARTTLS=true
TICKIFY_SMTP_SSL=false
TICKIFY_EMAIL_VERIFY_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Optional branding
TICKIFY_LOGO_URL=
